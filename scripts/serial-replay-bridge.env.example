# Copie para /etc/default/serial-replay-bridge (sem .example) e ajuste.
# systemd carrega este arquivo se a unidade usar EnvironmentFile=-/etc/default/serial-replay-bridge

SERIAL_PORT=/dev/ttyUSB0
SERIAL_BAUD=115200
REPLAY_URL=http://127.0.0.1:8000/hooks/replay-trigger
REPLAY_HOOK_SECRET=troque-pelo-mesmo-da-api
# REPLAY_SERIAL_COMMAND=REPLAY_CUT
