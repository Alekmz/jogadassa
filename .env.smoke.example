# Copie para .env.smoke e use com:
#   docker compose --env-file .env.smoke --profile smoke up -d --build

# RTSP fake: cada câmera vira um path no mediamtx publicado por um container ffmpeg testsrc.
RTSP_URL_CAM1=rtsp://mediamtx:8554/cam1
RTSP_URL_CAM2=rtsp://mediamtx:8554/cam2
RTSP_URL_CAM3=rtsp://mediamtx:8554/cam3
RTSP_URL_CAM4=rtsp://mediamtx:8554/cam4

BUTTON1_CAMERAS=cam1,cam2
BUTTON2_CAMERAS=cam3,cam4

# Janela e segmentos curtos para o smoke ser rápido (~1 min total)
SEGMENT_SECONDS=15
REPLAY_TRIGGER_WINDOW_SECONDS=10
RETENTION_DAYS=14

REPLAY_HOOK_SECRET=smoke-secret
SECRET_KEY=smoke-key
ADMIN_USERNAME=admin
ADMIN_PASSWORD=smoke
DATABASE_URL=sqlite:////data/app.db
DATA_DIR=/data
