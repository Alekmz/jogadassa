# Copie para .env e ajuste

# Câmera Intelbras (RTSP) — exemplo; o path exato depende do modelo
RTSP_URL=rtsp://admin:SENHA@192.168.1.100:554/cam/realmonitor?channel=1&subtype=0

# Gravação
SEGMENT_SECONDS=300
RETENTION_DAYS=14
DATA_DIR=/data

# API / auth (troque em produção)
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Banco (SQLite por padrão no edge)
DATABASE_URL=sqlite:////data/app.db

# JWT para links de download (segundos)
DOWNLOAD_TOKEN_EXPIRE_SECONDS=86400

# Pagamento MVP: manual | webhook_stub
PAYMENT_PROVIDER=manual
PAYMENT_WEBHOOK_SECRET=webhook-secret-change
BUSINESS_MODE=custom
