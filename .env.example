# Copie para .env e ajuste

# Ativa o serviço replay-bridge no `docker compose up` (USB serial → botão).
# Comente ou apague em Docker Desktop Mac/Windows se não houver dispositivo serial.
COMPOSE_PROFILES=bridge

# Câmeras (RTSP) — uma URL por câmera; 4 câmeras no total (2 por botão).
# Exemplos Intelbras; o path exato depende do modelo.
RTSP_URL_CAM1=rtsp://admin:SENHA@192.168.1.101:554/cam/realmonitor?channel=1&subtype=0
RTSP_URL_CAM2=rtsp://admin:SENHA@192.168.1.102:554/cam/realmonitor?channel=1&subtype=0
RTSP_URL_CAM3=rtsp://admin:SENHA@192.168.1.103:554/cam/realmonitor?channel=1&subtype=0
RTSP_URL_CAM4=rtsp://admin:SENHA@192.168.1.104:554/cam/realmonitor?channel=1&subtype=0

# Mapeamento botão → câmeras (CSV de IDs; precisa bater com os RTSP_URL_CAMx acima)
BUTTON1_CAMERAS=cam1,cam2
BUTTON2_CAMERAS=cam3,cam4

# Gravação
SEGMENT_SECONDS=300
RETENTION_DAYS=14
DATA_DIR=/data

# API / auth (troque em produção)
SECRET_KEY=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# Banco (SQLite por padrão no edge)
DATABASE_URL=sqlite:////data/app.db

# JWT para links de download (segundos)
DOWNLOAD_TOKEN_EXPIRE_SECONDS=86400

# Gatilho de replay (botões na quadra / Arduino) — POST /hooks/replay-trigger/{button_id}
# com header X-Replay-Secret. button_id válido: "1" ou "2".
REPLAY_TRIGGER_WINDOW_SECONDS=30
REPLAY_HOOK_SECRET=dev-replay-secret-change-me
# Opcional: serviços replay-bridge-1/2 no Docker (perfil bridge) — uma porta USB por botão (Linux)
# SERIAL_DEVICE_BUTTON1=/dev/ttyUSB0
# SERIAL_DEVICE_BUTTON2=/dev/ttyUSB1
# SERIAL_BAUD=115200
# REPLAY_SERIAL_COMMAND=REPLAY_CUT
# Base URL absoluta para montar links no WhatsApp (ex.: http://192.168.0.10:8000)
PUBLIC_BASE_URL=

# Pagamento MVP: manual | webhook_stub
PAYMENT_PROVIDER=manual
PAYMENT_WEBHOOK_SECRET=webhook-secret-change
BUSINESS_MODE=custom
